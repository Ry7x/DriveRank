  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Stores individual user profile information."
        }
      },
      {
        "path": "/radar_reports/{reportId}",
        "definition": {
          "entityName": "RadarReport",
          "description": "Stores community radar reports."
        }
      },
       {
        "path": "/public_runs/{runId}",
        "definition": {
          "entityName": "PerformanceRun",
          "description": "Stores public racing records."
        }
      }
    ]
  }
