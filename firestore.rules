
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Rekordet publike të garave (Ranking)
    match /public_runs/{runId} {
      allow get, list: if signedIn();
      allow create: if signedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if signedIn() && request.auth.uid == resource.data.userId;
    }

    // Profilet e përdoruesve dhe garat e tyre
    match /users/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);

      match /runs/{runId} {
        allow get, list: if signedIn();
        allow create: if isOwner(userId);
        allow update, delete: if isOwner(userId);
      }
    }

    // Raportet e komunitetit për radarë
    match /radar_reports/{reportId} {
      allow get, list: if signedIn();
      allow create: if signedIn();
      allow update: if signedIn() && resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && (
        !('userId' in resource.data) || resource.data.userId == request.auth.uid
      );
    }
    
    // Versioni i rregullave: 21.0 - Emoji Update dhe Siguri Mobile e Plotë
  }
}
